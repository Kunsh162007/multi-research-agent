# Required — free key at https://console.groq.com → API Keys
GROQ_API_KEY=your_groq_api_key_here

# Model — llama-3.3-70b-versatile is free and highly capable
# Other free options: llama-3.1-8b-instant (faster), mixtral-8x7b-32768
MODEL=llama-3.3-70b-versatile

# ── Multi-model router tiers (optional overrides — all free) ────────────────────
# Roles: fast (grading) · heavy (drafting) · reason (verify/contradiction) ·
#        vision (images) · long (long-context synthesis)
# MODEL_FAST=llama-3.1-8b-instant
# MODEL_HEAVY=llama-3.3-70b-versatile
# MODEL_REASON=openai/gpt-oss-120b
# MODEL_VISION_GROQ=meta-llama/llama-4-scout-17b-16e-instruct

# Gemini (free) — enables image vision + 1M-token long-context synthesis.
# Get a free key at https://aistudio.google.com/apikey . Leave blank to stay Groq-only.
GEMINI_API_KEY=
# MODEL_VISION_GEMINI=gemini-2.0-flash
# MODEL_LONG_GEMINI=gemini-2.0-flash

# ── Web-wide deep search (self-hosted SearXNG, no key) ──────────────────────────
# Bring it up with: docker compose -f docker-compose.searxng.yml up -d
# Then set the URL below. Empty → falls back to Tavily/stub web search.
SEARXNG_URL=
USE_SEARXNG=false
USE_DEEP_CRAWL=false      # follow links from search hits (BFS crawl)
USE_CONSENSUS=false       # draft on two models, judge merges (slower, +accuracy)
CRAWL_MAX_PAGES=12
CRAWL_MAX_DEPTH=2

# Google OAuth — create at https://console.cloud.google.com/apis/credentials
GOOGLE_CLIENT_ID=your_google_client_id.apps.googleusercontent.com

# JWT signing secret — generate a strong random string for production
JWT_SECRET=change_this_to_a_strong_random_secret

# Optional: real web search (if absent, stub results are used)
# Free tier at https://app.tavily.com — 1000 searches/month free
TAVILY_API_KEY=

# DB file paths — safe to leave as defaults
CHECKPOINT_DB=checkpoints.db
HISTORY_DB=history.db
MONITOR_DB=monitor.db

# Agent behaviour
MAX_ITERATIONS=8
QUALITY_TARGET=75
TOP_K=5

# Monitor: how often to auto-refresh user topics (hours)
MONITOR_INTERVAL_HOURS=24

# CORS — comma-separated list of allowed frontend origins
CORS_ORIGINS=http://localhost:5173
